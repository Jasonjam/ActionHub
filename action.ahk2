; testOneShot(*){
;     __ShowTip("執行單次動作中...")
;     Sleep(2000)
;     __OneShotDone(A_ThisFunc)
; }
test__SleepTimer(*) {
    ; 1. 執行長達 5 秒的倒數
    ; 傳入 A_ThisFunc 讓 __SleepTimer 監控這個函式的開關狀態
    __SleepTimer(5000, A_ThisFunc, "測試倒數")
    
    ; 3. 如果是 OneShot，記得關閉 GUI 狀態
    __OneShotDone(A_ThisFunc)
}
